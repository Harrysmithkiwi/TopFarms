[0:a]lowpass=f=160,volume=0.07,afade=t=in:st=0:d=1.5,afade=t=out:st=5.0:d=2.2[drone];
[1:a]lowpass=f=220,volume=0.035,afade=t=in:st=0:d=1.8,afade=t=out:st=5.0:d=2.2[drone2];
[2:a]bandpass=f=1500:w=1400,tremolo=f=13:d=0.8,volume='if(between(t\,1.8\,4.72)\,0.12*min(1\,(t-1.8)/2.4)\,0)':eval=frame[clutter];
[3:a]lowpass=f=200,volume='if(gte(t\,4.78)\,0.55*exp(-(t-4.78)*3.0)\,0)':eval=frame[hit];
[4:a]lowpass=f=120,volume='if(gte(t\,4.78)\,0.45*exp(-(t-4.78)*2.4)\,0)':eval=frame[sub];
[5:a]highpass=f=2000,volume='if(between(t\,4.78\,4.95)\,0.22*exp(-(t-4.78)*20)\,0)':eval=frame[tick];
[6:a]lowpass=f=400,volume='if(between(t\,6.0\,9.0)\,0.02*min(1\,(t-6)/1.2)*max(0\,1-(t-7.8)/1.2)\,0)':eval=frame[breath];
[drone][drone2][clutter][hit][sub][tick][breath]amix=inputs=7:normalize=0,alimiter=limit=0.95,aformat=channel_layouts=stereo:sample_rates=48000[out]

VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe (frontend — Vite-bundled, exposed to browser; safe by Stripe.js design)
# Use pk_test_* during development (Stripe sandbox), pk_live_* in production.
# Pre-launch swap to live tracked in .planning/DECISIONS-PENDING.md PEND-01.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_actual

# Stripe (backend — server-side only; lives in Supabase Edge Function secrets,
# not in this .env file. Listed here so onboarding devs know they exist):
#   STRIPE_SECRET_KEY            — sk_test_* (dev) / sk_live_* (prod)
#   STRIPE_WEBHOOK_SECRET        — test-mode webhook signing secret (dev) /
#                                  live-mode webhook signing secret (prod)
# Set via: supabase secrets set STRIPE_SECRET_KEY=sk_..._xxx --project-ref inlagtgpynemhipnqvty

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Environment files
.env
.env.local
.env.production

# Local MCP config (project-specific server config; secrets via env var)
.mcp.json

# Editor
.DS_Store
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# TypeScript cache
*.tsbuildinfo

# Vitest
coverage/
supabase/.temp/

# Deno (Edge Function local typecheck cache; Supabase CLI handles deps at deploy time)
deno.lock

# Claude Code runtime state (per-machine, not project state)
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Playwright E2E
tests/e2e/.auth/
playwright-report/
test-results/

# Rendered video outputs (regenerable from the HyperFrames source — keep big binaries out of git)
video-assets/**/*.mp4
video-assets/**/*.wav
